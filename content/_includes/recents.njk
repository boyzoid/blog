{% if collections.recents %}
<div id="recents" class="mb-8">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-400 mb-3">Recent posts</p>
    <ul class="list-none pl-0 space-y-2">
        {% for recent in collections.recents %}
        <li class="truncate">
            <a href="{{ recent.url }}" class="text-xs text-gray-600 dark:text-gray-300 hover:text-giants-800 dark:hover:text-giants-200 no-underline transition-colors">{{ recent.data.title }}</a>
        </li>
        {% endfor %}
    </ul>
</div>
{% endif %}

<ul class="list-none pl-0">
    {% for post in postslist | reverse %}
        <li class="mb-3 px-4 py-2 rounded-md hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
            <span class="text-sm tabular-nums text-gray-400 dark:text-gray-400 mr-3">{{ post.date | readableDate }}</span>
            <a href="{{ post.url }}" class="text-gray-700 dark:text-gray-200 hover:text-giants-800 dark:hover:text-giants-200 no-underline transition-colors">{{ post.data.title }}</a>
        </li>
    {% endfor %}
</ul>
